DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

DATABASE_ENGINE=django.db.backends.postgresql
DATABASE_NAME=django_rag
DATABASE_USER=django
DATABASE_PASSWORD=django
DATABASE_HOST=postgres
DATABASE_PORT=5432

REDIS_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

PINECONE_API_KEY=pclocal
PINECONE_URL=http://pinecone.local:5080
PINECONE_INDEX_HOST=http://pinecone.local:5081
PINECONE_INDEX=django-rag
PINECONE_NAMESPACE=documents
PINECONE_DIMENSION=768  # Dimension of the embedding vectors, e.g., 768 for nomic-embed-text or 384 for all-MiniLM-L6-v2
PINECONE_METRIC=cosine  # Similarity metric to use for vector search (e.g., cosine, euclidean, dotproduct)

OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_CHAT_MODEL=llama3.2:3b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_STARTUP_DELAY=15
EMBEDDING_BACKEND=ollama
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

RAG_CHUNK_SIZE=1000  # Number of characters in each chunk when splitting documents for RAG
RAG_CHUNK_OVERLAP=150  # Number of characters to overlap between chunks to maintain context
RAG_TOP_K=4  # Number of top relevant chunks to retrieve from the vector store for RAG
RAG_MAX_CONTEXT_CHARS=5000  # Maximum number of characters from retrieved chunks to include in the context for the LLM during RAG
